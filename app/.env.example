# ---- 3DotPay mobile environment ----
# Copy to .env. Only EXPO_PUBLIC_* vars are exposed to the app bundle.
# Do NOT put secrets here — anything EXPO_PUBLIC_* ships in the client build.

# Privy app id (public client identifier from the Privy dashboard).
EXPO_PUBLIC_PRIVY_APP_ID=cmquz0zrv00o00claz2101d89
# Optional: Privy app *client* id (dashboard → Clients), if your app requires one.
EXPO_PUBLIC_PRIVY_CLIENT_ID=

# Backend API base URL (use your LAN IP for a physical device, e.g. http://192.168.1.10:8080)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# Base chain id: 8453 (mainnet) or 84532 (Base Sepolia)
EXPO_PUBLIC_BASE_CHAIN_ID=8453
