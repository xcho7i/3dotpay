# ---- 3DotPay API environment ----
# Copy to .env and fill in. NEVER commit a real .env. Empty values are treated
# as "unset" and fall back to defaults where one exists.

# Server
NODE_ENV=development
PORT=8080
# Comma-separated list of allowed origins, or * for all (dev only).
CORS_ORIGIN=*
LOG_LEVEL=info

# MongoDB (optional for /health; connection is attempted at startup when set)
MONGODB_URI=mongodb://127.0.0.1:27017/3dotpay

# Privy — backend verifies Privy access tokens in auth middleware (next phase).
# PRIVY_APP_ID is a public client id; PRIVY_APP_SECRET is a SECRET. TODO: real values.
PRIVY_APP_ID=cmquz0zrv00o00claz2101d89
PRIVY_APP_SECRET=

# Base chain
BASE_RPC_URL=https://mainnet.base.org
BASE_CHAIN_ID=8453
# Native USDC on Base mainnet (public address; safe to commit).
USDC_CONTRACT_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Confirmation monitor poll interval (ms).
CHAIN_POLL_INTERVAL_MS=15000

# Settlement partner wallet — user USDC is sent directly here. TODO: real address.
SETTLEMENT_WALLET_ADDRESS=

# Settlement partner: mock | aeon | ksher. Mock is the local-dev default.
SETTLEMENT_PARTNER=mock

# AEON (required when SETTLEMENT_PARTNER=aeon in production). TODO: real values.
AEON_API_BASE_URL=
AEON_API_KEY=

# KSHER (required when SETTLEMENT_PARTNER=ksher in production). TODO: real values.
KSHER_API_BASE_URL=
KSHER_API_KEY=
